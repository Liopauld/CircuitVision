# Server configuration
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# MongoDB — local default or Atlas connection string
MONGO_URI=mongodb://localhost:27017/circuitvision

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Cloudinary (image storage). Leave blank to run with uploads stubbed.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email. APP_BASE_URL is the client origin used to build verify/reset links
# (defaults to the first CLIENT_ORIGIN entry). Leave SMTP_URL blank to run the
# mock mailer — links are logged to the server console and returned in dev API
# responses, so the flows work without a real inbox.
APP_BASE_URL=http://localhost:5173
MAIL_FROM=CircuitVision <no-reply@circuitvision.test>
SMTP_URL=
